#!/bin/bash
#
# Smart Dictation Starter
# Detects keyboard layout using xkblayout-state and runs the appropriate engine.
# English → VOSK, Arabic → Whisper (faster-whisper, much better accuracy).
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1090
source "$SCRIPT_DIR/lib_common.sh"
NERD_DICTATION="$SCRIPT_DIR/nerd-dictation"
STATE_FILE="$HOME/.dictate-state"
MODEL_BASE="$HOME/.config/nerd-dictation"
TIMEOUT=7

# Load runtime switches (env vars override values set in this file).
if [ -f "$MODEL_BASE/config.sh" ]; then
    # shellcheck disable=SC1090
    source "$MODEL_BASE/config.sh"
fi

# ── Auto-start the voice-controller tray icon if it is not running ─────────
VC_SCRIPT="$SCRIPT_DIR/voice-controller/voice-controller.py"
if [ -f "$VC_SCRIPT" ] && ! pgrep -f "voice-controller.py" > /dev/null 2>&1; then
    nohup /usr/bin/python3 "$VC_SCRIPT" \
        >> "$HOME/.local/share/voice-controller/controller.log" 2>&1 &
    # Give the tray a moment to register with the system tray
    sleep 1
fi
# ───────────────────────────────────────────────────────────────────────────

# Validate ENGLISH_ENGINE against the canonical backend registry (fail fast on typos).
if ! python3 "$SCRIPT_DIR/backends.py" validate "$ENGLISH_ENGINE" >/dev/null 2>&1; then
    zenity --error --title="Dictation Error" \
        --text="Unknown ENGLISH_ENGINE: $ENGLISH_ENGINE\n\nValid engines: VOSK, WHISPER, WLK"
    notify-send "Dictation Failed" "Unknown ENGLISH_ENGINE: $ENGLISH_ENGINE" \
        --icon=dialog-error --app-name="nerd-dictation" 2>/dev/null
    exit 1
fi

# Validate WHISPER_DAEMON_MODE
case "$WHISPER_DAEMON_MODE" in
    warm-cache|ipc) ;;
    *) zenity --error --title="Dictation Error" \
        --text="Unknown WHISPER_DAEMON_MODE: $WHISPER_DAEMON_MODE\n\nValid: warm-cache, ipc"
       exit 1 ;;
esac

# Export WHISPER transcript settings into the environment so the WHISPER path
# (whisper-daemon / nerd-dictation WHISPER engine) inherits them. Empty by
# default -> the export hook is a no-op. VOSK doesn't use these.
export WHISPER_EXPORT_PATH
export OUTPUT_FORMAT
export PUNCTUATE
# Whisper quantization.
export COMPUTE_TYPE
# Per-language Whisper model map.
export LANG_MODELS
# Transcript autosave + undo-last tracking.
export AUTOSAVE_PATH
export LAST_UTTERANCE_FILE
# VAD tuning for the VOSK (VAD_GATE) path.
export VAD_THRESHOLD
export VAD_MIN_SILENCE_MS
# WLK streaming tuning.
export WLK_CHUNK
export WLK_MODEL
export WLK_LANG
export WLK_POLICY
export AUTO_LANG

# Parse arguments
VERBOSE=false
if [ "$1" = "--verbose" ] || [ "$1" = "-v" ]; then
    VERBOSE=true
    exec > >(tee /tmp/dictate-start.log) 2>&1
    echo "=== Verbose mode enabled ==="
fi

# Ensure nerd-dictation exists
if [ ! -f "$NERD_DICTATION" ]; then
    zenity --error --title="Dictation Error" --text="nerd-dictation not found at:\n$NERD_DICTATION\n\nRun setup.sh to install."
    exit 1
fi

# Check if already running
if [ -f "$STATE_FILE" ]; then
    PID=$(grep "^PID:" "$STATE_FILE" 2>/dev/null | cut -d: -f2)
    if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
        zenity --info --title="Dictation" --text="Dictation is already running.\nPress your stop shortcut to stop first."
        exit 1
    else
        rm -f "$STATE_FILE"
    fi
fi

# Get current keyboard layout using xkblayout-state
CURRENT_LAYOUT=$(xkblayout-state print "%s" 2>/dev/null | tr -d ' ')

if [ -z "$CURRENT_LAYOUT" ]; then
    zenity --error --title="Dictation Error" --text="Could not detect keyboard layout.\nIs xkblayout-state installed?"
    exit 1
fi

# Auto-detect audio recording tool: prefer parec (PulseAudio/PipeWire-pulse),
# fall back to pw-cat (native PipeWire), then sox.
if command -v parec &>/dev/null; then
    INPUT_METHOD="PAREC"
elif command -v pw-cat &>/dev/null; then
    INPUT_METHOD="PW-CAT"
elif command -v sox &>/dev/null; then
    INPUT_METHOD="SOX"
else
    zenity --error --title="Dictation Error" --text="No audio recording tool found.\n\nInstall one of:\n  sudo apt install pulseaudio-utils\n  sudo apt install pipewire-audio-client-libraries"
    exit 1
fi

# Auto-detect GPU: use CUDA if nvidia-smi reports a GPU, otherwise CPU.
if command -v nvidia-smi &>/dev/null && nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | grep -q .; then
    WHISPER_DEVICE="cuda"
else
    WHISPER_DEVICE="cpu"
fi

# Map layout to engine and model settings
USE_WHISPER=false
USE_WLK=false
case "$CURRENT_LAYOUT" in
    us)
        LANG_NAME="English"
        LANG_CODE="us"
        if [ "$ENGLISH_ENGINE" = "WHISPER" ]; then
            USE_WHISPER=true
            WHISPER_MODEL="$ENGLISH_WHISPER_MODEL"   # small.en
            WHISPER_LANG="en"
            WHISPER_TOOL="XDOTOOL"
        elif [ "$ENGLISH_ENGINE" = "WLK" ]; then
            USE_WLK=true
            USE_WHISPER=false
        else
            USE_WHISPER=false
            MODEL_DIR="$MODEL_BASE/vosk-model-en-us-0.22"
            VOSK_GRAMMAR="$MODEL_BASE/grammar-en-tech.json"
            # vosk-model-en-us-0.22 is a large Kaldi model — it does NOT support
            # runtime grammar graphs. Only pass grammar for small/dynamic models.
            # Detection: check for graph/HCLG.fst which signals grammar support.
            if [ -f "$MODEL_DIR/graph/HCLG.fst" ]; then
                MODEL_SUPPORTS_GRAMMAR=true
            else
                MODEL_SUPPORTS_GRAMMAR=false
            fi
        fi
        ;;
    ara)
        LANG_NAME="Arabic"
        LANG_CODE="ara"
        USE_WHISPER=true
        WHISPER_MODEL="$ARABIC_WHISPER_MODEL"         # small
        WHISPER_LANG="ar"
        WHISPER_TOOL="CLIPBOARD"
        ;;
    *)
        zenity --error --title="Unsupported Layout" --text="Unsupported keyboard layout: $CURRENT_LAYOUT\n\nSupported layouts:\n• us (English)\n• ara (Arabic)"
        notify-send "Dictation Failed" "Unsupported layout: $CURRENT_LAYOUT" --icon=dialog-error --app-name="nerd-dictation" 2>/dev/null
        exit 1
        ;;
esac

# Resolve the Whisper model for the active language, honoring LANG_MODELS
# overrides (lang:model pairs). Falls back to WHISPER_MODEL set in the case above.
# WHISPER_LANG holds the Whisper language code (en/ar/...).
if [ "$USE_WHISPER" = "true" ]; then
    WHISPER_MODEL="$(resolve_whisper_model "$WHISPER_LANG" "$WHISPER_MODEL")"
fi

# For VOSK engine: check that the model directory exists
if [ "$USE_WLK" = "false" ] && [ "$USE_WHISPER" = "false" ] && [ ! -d "$MODEL_DIR" ]; then
    zenity --error --title="Model Not Found" --text="$LANG_NAME model not installed.\n\nPath: $MODEL_DIR\n\nDownload from:\nhttps://alphacephei.com/vosk/models"
    notify-send "Dictation Failed" "$LANG_NAME model not found" --icon=dialog-error --app-name="nerd-dictation" 2>/dev/null
    exit 1
fi

# Kill any orphaned dictation processes
pkill -f "nerd-dictation begin" 2>/dev/null
sleep 0.3

# Start dictation
if [ "$USE_WLK" = "true" ]; then
    ENGINE="WLK"
    WLK_MODEL="${WLK_MODEL:-small}"
    WLK_LANG="${WLK_LANG:-en}"
    WLK_READY_FILE="$HOME/.cache/nerd-dictation/wlk-ready"
    rm -f "$WLK_READY_FILE"
    "$SCRIPT_DIR/wlk-daemon.py" --model "$WLK_MODEL" --language "$WLK_LANG" \
        >> /tmp/nerd-dictation-en.log 2>&1 &
    WLK_PID=$!
    # Wait for WLK server to come up; fall back to VOSK if it doesn't.
    READY=0
    for _ in $(seq 1 "${WLK_READY_TIMEOUT:-30}"); do
        if [ -f "$WLK_READY_FILE" ]; then READY=1; break; fi
        if ! kill -0 "$WLK_PID" 2>/dev/null; then break; fi
        sleep 1
    done
    if [ "$READY" = "1" ]; then
        PID=$WLK_PID
        echo "Started English dictation (engine: WLK)" >> /tmp/nerd-dictation-en.log
    else
        # Fallback: stop WLK, run VOSK instead.
        # Kill the daemon AND its direct children (the whisperlivekit server)
        # so no orphan streaming/typing process survives and double-runs with VOSK.
        pkill -P "$WLK_PID" 2>/dev/null
        kill "$WLK_PID" 2>/dev/null
        pkill -f "whisperlivekit" 2>/dev/null
        echo "WLK failed to start in time — falling back to VOSK" >> /tmp/nerd-dictation-en.log
        ENGINE="VOSK"
        USE_WHISPER=false
        MODEL_DIR="$MODEL_BASE/vosk-model-en-us-0.22"
        VOSK_GRAMMAR="$MODEL_BASE/grammar-en-tech.json"
        VOSK_GRAMMAR_ARGS=()
        # vosk-model-en-us-0.22 doesn't support runtime grammar graphs — skip
        if [ "${MODEL_SUPPORTS_GRAMMAR:-false}" = "true" ] && [ -n "$VOSK_GRAMMAR" ] && [ -f "$VOSK_GRAMMAR" ]; then
            VOSK_GRAMMAR_ARGS=(--vosk-grammar-file "$VOSK_GRAMMAR")
        fi
        if [ "${VAD_GATE:-off}" = "on" ] && command -v parec &>/dev/null; then
            dev_args=()
            [ -n "${AUDIO_DEVICE:-}" ] && dev_args=(--device "$AUDIO_DEVICE")
            parec --record --rate=16000 --channels=1 --format=s16le --latency=10 "${dev_args[@]}" 2>/dev/null \
                | "$SCRIPT_DIR/vad_gate.py" \
                | "$NERD_DICTATION" begin --vosk-model-dir="$MODEL_DIR" \
                    --input VADPIPE --timeout=$VOSK_TIMEOUT \
                    "${VOSK_GRAMMAR_ARGS[@]}" --verbose 1 >> /tmp/nerd-dictation-en.log 2>&1 &
        else
            "$NERD_DICTATION" begin --vosk-model-dir="$MODEL_DIR" --input "$INPUT_METHOD" \
                --timeout=$VOSK_TIMEOUT "${VOSK_GRAMMAR_ARGS[@]}" --verbose 1 >> /tmp/nerd-dictation-en.log 2>&1 &
        fi
        PID=$!
    fi
elif [ "$USE_WHISPER" = "true" ]; then
    ENGINE="WHISPER"
    DAEMON_MODE_ARGS=(--whisper-daemon-mode "$WHISPER_DAEMON_MODE")
    if [ "$WHISPER_DAEMON_MODE" = "ipc" ]; then
        DAEMON_MODE_ARGS+=(--whisper-socket "$WHISPER_SOCKET")
    fi
    # honor DICTATION_TARGET config settings
    WHISPER_TOOL_ACTUAL="$WHISPER_TOOL"
    if [ "$DICTATION_TARGET" = "Clipboard" ]; then
        WHISPER_TOOL_ACTUAL="STDOUT"
    fi
    # Logs go to /tmp/nerd-dictation-ar.log — check this file to debug Arabic issues
    "$NERD_DICTATION" begin \
        --engine WHISPER \
        --whisper-model "$WHISPER_MODEL" \
        --whisper-device "$WHISPER_DEVICE" \
        --language "$WHISPER_LANG" \
        --simulate-input-tool "$WHISPER_TOOL_ACTUAL" \
        --input "$INPUT_METHOD" \
        --timeout=$TIMEOUT \
        "${DAEMON_MODE_ARGS[@]}" \
        --verbose 1 >> /tmp/nerd-dictation-ar.log 2>&1 &
else
    ENGINE="VOSK"
    VOSK_GRAMMAR_ARGS=()
    if [ "${MODEL_SUPPORTS_GRAMMAR:-false}" = "true" ] && [ -n "$VOSK_GRAMMAR" ] && [ -f "$VOSK_GRAMMAR" ]; then
        VOSK_GRAMMAR_ARGS=(--vosk-grammar-file "$VOSK_GRAMMAR")
    fi
    # honor DICTATION_TARGET config settings
    VOSK_OUTPUT_METHOD="SIMULATE_INPUT"
    if [ "$DICTATION_TARGET" = "Clipboard" ]; then
        VOSK_OUTPUT_METHOD="STDOUT"
    fi
    # Logs go to /tmp/nerd-dictation-en.log — check this file to debug English issues
    if [ "${VAD_GATE:-off}" = "on" ] && command -v parec &>/dev/null; then
        # VAD-gated capture: parec -> Silero VAD gate -> nerd-dictation (reads stdin).
        dev_args=()
        [ -n "${AUDIO_DEVICE:-}" ] && dev_args=(--device "$AUDIO_DEVICE")
        parec --record --rate=16000 --channels=1 --format=s16le --latency=10 "${dev_args[@]}" 2>/dev/null \
            | "$SCRIPT_DIR/vad_gate.py" \
            | "$NERD_DICTATION" begin \
                --vosk-model-dir="$MODEL_DIR" \
                --input VADPIPE \
                --timeout=$VOSK_TIMEOUT \
                --output "$VOSK_OUTPUT_METHOD" \
                "${VOSK_GRAMMAR_ARGS[@]}" --verbose 1 >> /tmp/nerd-dictation-en.log 2>&1 &
    else
        "$NERD_DICTATION" begin \
            --vosk-model-dir="$MODEL_DIR" \
            --input "$INPUT_METHOD" \
            --timeout=$VOSK_TIMEOUT \
            --output "$VOSK_OUTPUT_METHOD" \
            "${VOSK_GRAMMAR_ARGS[@]}" --verbose 1 >> /tmp/nerd-dictation-en.log 2>&1 &
    fi
fi
PID=$!

# Save state (ENGINE is read by dictate-stop to decide how long to wait)
cat > "$STATE_FILE" << EOF
PID:$PID
LANG:$LANG_CODE
LANG_NAME:$LANG_NAME
ENGINE:$ENGINE
TIME:$(date +%s)
EOF

# For Whisper: show a "loading" notification now.
# A second "Dictation Ready" notification fires from Python once the model
# is loaded and recording has actually started — wait for that before speaking.
if [ "$USE_WHISPER" = "true" ]; then
    notify-send "Dictation Loading" "Loading Arabic model, please wait..." --icon=microphone --app-name="nerd-dictation" 2>/dev/null || true
else
    notify-send "Dictation Started" "$LANG_NAME dictation is now listening..." --icon=microphone --app-name="nerd-dictation" 2>/dev/null || true
fi

echo "Started $LANG_NAME dictation (PID: $PID, engine: $ENGINE, input: $INPUT_METHOD, timeout: ${TIMEOUT}s)"
exit 0
